{
  "manifest_version": 2,
  "name": "Content Signing",
  "version": "1.0.0",
  "description": "Sign and verify web content using WebAuthn",
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["assets/content.css"]
    }
  ],
  "permissions": [
    "storage",
    "tabs",
    "notifications",
    "https://*/*"
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "web_accessible_resources": [
    "assets/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "content-signing@example.com",
      "strict_min_version": "57.0"
    }
  }
}